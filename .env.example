# StarBridge local configuration template.
# Copy to .env for local use. Do not commit real paths, tokens, accounts, model names, or asset directories.

STARBRIDGE_PROBE_TIMEOUT=8
STARBRIDGE_DOWNLOAD_INBOX=<local-download-inbox>

# ComfyUI
STARBRIDGE_COMFYUI_URL=http://127.0.0.1:8188
COMFY_ROOT=<path-to-ComfyUI>
COMFY_LAUNCHER=<path-to-ComfyUI-launcher>
COMFY_OUTPUT_DIR=<path-to-ComfyUI-output>

# Blender
STARBRIDGE_BLENDER_EXE=<path-to-blender.exe>
BLENDER_MCP_DIR=<path-to-blender-mcp>

# AutoCAD / CAD
STARBRIDGE_CAD_MODE=autocad
AUTOCAD_EXE=<path-to-acad.exe>

# Adobe Photoshop
PHOTOSHOP_EXE=<path-to-Photoshop.exe>

# Adobe Illustrator
ILLUSTRATOR_EXE=<path-to-Illustrator.exe>

# Jianying / CapCut
JIANYING_EXE=<path-to-jianying.exe>
JIANYING_DRAFTS_DIR=<path-to-jianying-drafts>
CAPCUT_EXE=<path-to-capcut.exe>
CAPCUT_DRAFTS_DIR=<path-to-capcut-drafts>
